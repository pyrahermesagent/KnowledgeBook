# --- Google OAuth (https://console.cloud.google.com/apis/credentials) ---
# Authorized redirect URI: <origin>/api/auth/google
NUXT_OAUTH_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=your-client-secret
# Public callback URL. REQUIRED when running behind a reverse proxy, otherwise
# the app derives it from the internal request URL and Google rejects the
# sign-in with "Error 400: redirect_uri_mismatch". Must exactly match the
# authorized redirect URI registered in Google Console.
# Production: https://knowledgebook.plutolabs.app/api/auth/google
NUXT_OAUTH_GOOGLE_REDIRECT_URL=http://localhost:3000/api/auth/google

# --- Session (random string, at least 32 characters) ---
NUXT_SESSION_PASSWORD=change-me-to-a-random-32+-char-string

# --- SQLite database file ---
NUXT_DATABASE_PATH=.data/knowledgebook.db

# --- Hetzner Object Storage (S3 compatible) ---
# If left empty, uploads fall back to local disk (NUXT_UPLOADS_DIR).
NUXT_S3_ENDPOINT=https://fsn1.your-objectstorage.com
NUXT_S3_REGION=fsn1
NUXT_S3_BUCKET=knowledgebook
NUXT_S3_ACCESS_KEY=
NUXT_S3_SECRET_KEY=
# Public base URL for uploaded objects (defaults to https://<bucket>.<endpoint-host>)
NUXT_S3_PUBLIC_URL=

# --- Local upload fallback directory ---
NUXT_UPLOADS_DIR=.data/uploads
