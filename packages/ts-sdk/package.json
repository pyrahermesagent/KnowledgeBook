{
  "name": "@knowledgebook/sdk",
  "version": "1.0.0",
  "description": "Official KnowledgeBook SDK for JavaScript/TypeScript",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsc && esbuild src/index.ts --bundle --platform=node --target=node18 --outfile=dist/index.js --format=esm",
    "build:browser": "tsc && esbuild src/index.ts --bundle --platform=browser --target=es2020 --outfile=dist/browser.js --format=iife --global-name=KnowledgeBook",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "prebuild": "rimraf dist",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "knowledgebook",
    "sdk",
    "api",
    "documentation",
    "mcp",
    "web3"
  ],
  "author": "KnowledgeBook Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/knowledgebook/sdk-js.git"
  },
  "bugs": {
    "url": "https://github.com/knowledgebook/sdk-js/issues"
  },
  "homepage": "https://github.com/knowledgebook/sdk-js#readme",
  "dependencies": {
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "esbuild": "^0.19.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.0.1",
    "prettier": "^3.1.0",
    "rimraf": "^5.0.5",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "viem": "^2.0.0"
  }
}
